{
  "name": "HollyDayz Dev",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:1-22-bookworm",

  "features": {
    "ghcr.io/devcontainers-community/features/supabase-cli:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },

  "postCreateCommand": "npm install && npm install -g vercel",

  "forwardPorts": [5173, 54321, 54322, 54323, 54324],
  "portsAttributes": {
    "5173": {
      "label": "Vite Dev Server",
      "onAutoForward": "notify"
    },
    "54321": {
      "label": "Supabase Studio",
      "onAutoForward": "notify"
    },
    "54322": {
      "label": "Supabase DB",
      "onAutoForward": "silent"
    },
    "54323": {
      "label": "Supabase Edge Functions",
      "onAutoForward": "silent"
    },
    "54324": {
      "label": "Supabase Inbucket (email)",
      "onAutoForward": "silent"
    }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "dsznajder.es7-react-js-snippets",
        "formulahendry.auto-rename-tag",
        "christian-kohler.path-intellisense",
        "ms-vscode.vscode-json",
        "supabase.vscode-supabase-extension",
        "github.copilot",
        "github.copilot-chat"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.tabSize": 2,
        "eslint.validate": ["javascript", "javascriptreact"],
        "terminal.integrated.defaultProfile.linux": "zsh"
      }
    }
  },

  "remoteEnv": {
    "NODE_ENV": "development"
  }
}
